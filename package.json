{
  "name": "localization-gen-node-monorepo",
  "private": true,
  "version": "0.0.3",
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "react:init": "npm run localization-gen:init --workspace=localization-gen-react-example",
    "react:generate": "npm run localization-gen:generate --workspace=localization-gen-react-example",
    "react:watch": "npm run localization-gen:watch --workspace=localization-gen-react-example",
    "react:validate": "npm run localization-gen:validate --workspace=localization-gen-react-example",
    "vue:init": "npm run localization-gen:init --workspace=localization-gen-vue-example",
    "vue:generate": "npm run localization-gen:generate --workspace=localization-gen-vue-example",
    "vue:watch": "npm run localization-gen:watch --workspace=localization-gen-vue-example",
    "vue:validate": "npm run localization-gen:validate --workspace=localization-gen-vue-example"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@types/node": "^22.15.3",
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "eslint": "^9.25.1",
    "jsdom": "^24.1.3",
    "turbo": "^2.5.0",
    "typescript": "^5.8.3",
    "vitest": "^1.6.1"
  }
}

