{
  "name": "localization-gen-react-example",
  "version": "0.0.3",
  "private": true,
  "type": "module",
  "scripts": {
    "localization-gen:init": "localization-gen init",
    "localization-gen:generate": "localization-gen generate",
    "localization-gen:watch": "localization-gen generate --watch",
    "localization-gen:validate": "localization-gen validate",
    "localization-gen:clean": "localization-gen clean",
    "localization-gen:coverage": "localization-gen coverage",
    "dev": "vite",
    "build": "tsc -p tsconfig.json && vite build",
    "test": "vitest run",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "localization-gen-core": "0.0.3",
    "localization-gen-react-adapter": "0.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "vite": "^5.4.10"
  }
}

