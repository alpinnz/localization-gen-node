        "description": "Teks banner berdasarkan konteks siklus pengguna."
      }
    },
    "host_title": {
      "@gender": {
        "male": "Dipandu Bpk. {last_name}",
        "female": "Dipandu Ibu {last_name}",
        "other": "Dipandu Sdr. {last_name}"
      },
      "@host_title": {
        "description": "Label pemandu berdasarkan gender.",
        "placeholders": {
          "last_name": "Nama keluarga pemandu"
        }
      }
    }
