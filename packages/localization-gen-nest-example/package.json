{
  "name": "localization-gen-nest-example",
  "version": "0.0.5",
  "private": true,
  "type": "module",
  "scripts": {
    "core:build": "npm --prefix ../.. run build --workspace=localization-gen-core",
    "localization-gen:init": "npm run core:build && localization-gen init",
    "localization-gen:generate": "npm run core:build && localization-gen generate",
    "localization-gen:watch": "npm run core:build && localization-gen generate --watch",
    "localization-gen:validate": "npm run core:build && localization-gen validate",
    "localization-gen:clean": "npm run core:build && localization-gen clean",
    "localization-gen:coverage": "npm run core:build && localization-gen coverage",
    "dev": "node --loader ts-node/esm src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "test": "vitest run",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "localization-gen-core": "0.0.5",
    "localization-gen-nest-adapter": "0.0.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.15",
    "@types/express": "^4.17.21",
    "ts-node": "^10.9.2"
  }
}

