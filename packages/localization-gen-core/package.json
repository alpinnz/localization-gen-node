{
  "name": "localization-gen-core",
  "version": "0.0.3",
  "description": "Core compiler, validator, runtime primitives, and CLI for modular localization generation.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alpinnz/localization-gen-node.git",
    "directory": "packages/localization-gen-core"
  },
  "bugs": {
    "url": "https://github.com/alpinnz/localization-gen-node/issues"
  },
  "homepage": "https://github.com/alpinnz/localization-gen-node/tree/main/packages/localization-gen-core",
  "keywords": [
    "i18n",
    "l10n",
    "localization",
    "json",
    "codegen",
    "cli"
  ],
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./runtime": {
      "types": "./dist/browser.d.ts",
      "default": "./dist/browser.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "default": "./dist/browser.js"
    }
  },
  "bin": {
    "localization-gen": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -w -p tsconfig.build.json",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "prepack": "npm run clean && npm run build",
    "release:check": "npm run typecheck && npm run test && npm run build",
    "release:pack": "npm pack",
    "release:dry-run": "npm publish --dry-run",
    "release:pack:clean": "find . -maxdepth 1 -name \"*.tgz\" -delete"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "yaml": "^2.5.1"
  }
}
