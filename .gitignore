node_modules/
**/node_modules/

# Build outputs
**/dist/
**/coverage/
**/*.tsbuildinfo

# TypeScript emit artifacts inside example src/ directories
# (examples use Vite for compilation; tsc runs in noEmit/type-check mode only)
packages/*-example/src/**/*.js
packages/*-example/src/**/*.js.map
packages/*-example/src/**/*.d.ts
!packages/*-example/assets

# Caches
.turbo/
.npm/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment files
.env
.env.*
!.env.example

# Editor / OS
.DS_Store
.idea/
.vscode/

# Release artifacts
*.tgz

